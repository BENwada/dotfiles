// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "active_pane_modifiers": {
    "inactive_opacity": 0.7,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "terminal": {
    "env": {},
    "font_size": 15.0,
    "font_family": "FiraCode Nerd Font",
  },
  "base_keymap": "VSCode",
  "preview_tabs": {
    "enabled": false,
  },
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "never",
  },
  "cursor_shape": "bar",
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "linked_edits": true,
  "soft_wrap": "editor_width",
  "tab_size": 2,
  "icon_theme": "Catppuccin Latte",
  "ui_font_size": 16,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "Kanagawa Wave",
  },

  "experimental.theme_overrides": {
    "background.appearance": "transparent",
    "background": "#1f1f2870",
    "editor.background": "#1f1f2870",
    "editor.gutter.background": "#1f1f2870",
    "elevated_surface.background": "#1f1f2870",
    "surface.background": "#1f1f2870",
    "panel.background": "#1f1f2870",
    "tab_bar.background": "#1f1f28D9",
    "tab.active_background": "#1f1f28D9",
    "tab.inactive_background": "#1f1f28D9",
    "toolbar.background": "#1f1f28D9",
    "status_bar.background": "#1f1f28D9",
    "title_bar.background": "#1f1f28D9",
  },
}
